{
	"name": "electrobun-vue",
	"version": "1.0.0",
	"type": "module",
	"description": "Electrobun app with Vue and Vite HMR",
	"scripts": {
		"dev": "concurrently \"bun run dev:port\" \"bun run dev:nohmr\"",
		"dev:port": "vite --port 5173",
		"dev:nohmr": "electrobun dev --watch",
		"prodrun": "vite build && electrobun dev",
		"build:canary": "vite build && electrobun build --env=canary"
	},
	"dependencies": {
		"electrobun": "1.16.0",
		"music-metadata": "^11.12.3",
		"pinia": "^3.0.4"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"@vitejs/plugin-vue": "^6.0.6",
		"concurrently": "^9.1.0",
		"typescript": "^5.7.2",
		"vite": "^8.0.8",
		"vite-svg-loader": "^5.1.1",
		"vue": "^3.5.13",
		"vue-tsc": "^2.2.0"
	}
}
